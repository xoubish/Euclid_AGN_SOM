# data/ layout:
#   data/input/  human inputs (AGN catalogs + README). README and .gitkeep tracked; FITS files NOT tracked.
#   data/cache/  notebook-generated query/spectrum caches. Fully ignored except for .gitkeep.
/data/*
!/data/input/
!/data/cache/
/data/input/*
!/data/input/README.txt
!/data/input/.gitkeep
/data/cache/*
!/data/cache/.gitkeep

# Ignore large FITS files and other data products
*.fits
*.fit
*.fts
*.ecsv
*.csv
*.h5
*.hdf5
*.sav
*.npz

# Ignore notebook checkpoints and Python caches
.ipynb_checkpoints/
__pycache__/
*.py[cod]

# Ignore environment and IDE files
.env
.venv/
*.swp
*.swo
.DS_Store
